{
  "description": "CustomCSS - injects custom CSS into pages.",
  "manifest_version": 3,
  "name": "cucss",
  "version": "1.5",
  "homepage_url": "https://github.com/panacotar/cucss",
  "icons": {
    "16": "icons/cucss16.png",
    "32": "icons/cucss32.png",
    "64": "icons/cucss64.png",
    "48": "icons/cucss48.png",
    "128": "icons/cucss128.png"
  },

  "browser_specific_settings": {
    "gecko": {
      "id": "@addon-cucss",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  },

  "permissions": [
    "storage"
  ],

  "content_scripts": [
    {
      "matches": [ "<all_urls>" ],
      "js": ["scripts/content_script.js"]
    }
  ],

  "action": {
    "default_popup": "popup.html",
    "default_icon": "icons/cucss48.png"
  }
}